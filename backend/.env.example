# MultiAgent Kanban 配置
# 复制此文件为 .env 并修改所需的值
# 所有变量使用 MULTIAGENT_ 前缀

# Claude CLI 路径（默认使用 PATH 中的 claude）
# MULTIAGENT_CLAUDE_PATH=claude

# Claude 的 Git Bash 路径（Windows 下如需指定）
# MULTIAGENT_CLAUDE_GIT_BASH_PATH=

# 最大并行 Agent 数量
# MULTIAGENT_MAX_CONCURRENT_PROCESSES=3

# 数据库 URL（默认 SQLite）
# MULTIAGENT_DATABASE_URL=sqlite+aiosqlite:///./data/multiagent.db

# WebSocket 心跳间隔（秒）
# MULTIAGENT_WS_HEARTBEAT_INTERVAL=30

# 单条日志最大字符数
# MULTIAGENT_LOG_MAX_LENGTH=100000
